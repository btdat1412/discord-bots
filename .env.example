
# Ti Gia Bot Token
TI_GIA_BOT_TOKEN=your-bot-token-here
TI_GIA_DAILY_CHANNEL_ID=your-ti-gia-bot-channel-id

# Gym Rat Bot
GYM_RAT_BOT_TOKEN=your-gym-rat-bot-token-here
GYM_RAT_DATABASE_URL=postgresql://user:password@host:port/dbname
GYM_RAT_DAILY_CHANNEL_ID=your-channel-id

# S3 Storage (Cloudflare R2)
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET_NAME=gym-checkins
S3_ACCESS_KEY_ID=your-r2-access-key
S3_SECRET_ACCESS_KEY=your-r2-secret-key
# Public base URL for image hotlinking — when set, get_url() returns a public
# CDN URL instead of a presigned URL. For R2: enable "Public Development URL"
# in the bucket settings and use the pub-<hash>.r2.dev value, or attach a
# custom domain on Cloudflare and use that here.
PUBLIC_BASE_URL=https://pub-<hash>.r2.dev